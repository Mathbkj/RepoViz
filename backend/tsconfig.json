{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": ["ES2020"],
    "moduleResolution": "node16",
    "ignoreDeprecations": "6.0",
    "noImplicitAny": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@repo-viz/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "public"]
}
